#!name= CapCut Deep Interceptor
#!desc= Can thiệp sâu vào cơ chế CapCut - Giả lập đã xem ads và Premium
#!author= CapCut-Hacker

[General]
bypass-system = true
dns-server = system, 8.8.8.8, 1.1.1.1
ipv6 = false

# ===== LỚP 1: CHẶN HOÀN TOÀN REQUEST QUẢNG CÁO =====
[Rule]
# Chặn mọi request liên quan đến quảng cáo
DOMAIN-SUFFIX,capcut.com,PROXY
DOMAIN-SUFFIX,bytedance.com,PROXY
DOMAIN-SUFFIX,byteoversea.com,PROXY
DOMAIN-KEYWORD,ad,REJECT
DOMAIN-KEYWORD,ads,REJECT
DOMAIN-KEYWORD,track,REJECT
DOMAIN-KEYWORD,event,REJECT
DOMAIN-KEYWORD,report,REJECT
DOMAIN-KEYWORD,analytics,REJECT
DOMAIN-KEYWORD,monitor,REJECT
DOMAIN-KEYWORD,statistic,REJECT
DOMAIN-KEYWORD,log,REJECT

# ===== LỚP 2: URL REWRITE MẠNH =====
[URL Rewrite]
# === ADS ENDPOINTS ===
^https?:\/\/api\.capcut\.com\/api\/v1\/ad 302 https://api.capcut.com/api/v1/ad-completed
^https?:\/\/api\.capcut\.com\/api\/v1\/ads 302 https://api.capcut.com/api/v1/ads-completed
^https?:\/\/api\.capcut\.com\/api\/v1\/ad\/check 302 https://api.capcut.com/api/v1/ad-completed/check
^https?:\/\/api\.capcut\.com\/api\/v1\/ad\/view 302 https://api.capcut.com/api/v1/ad-viewed
^https?:\/\/api\.capcut\.com\/api\/v1\/ad\/skip 302 https://api.capcut.com/api/v1/ad-skipped
^https?:\/\/api\.capcut\.com\/api\/v1\/ad\/reward 302 https://api.capcut.com/api/v1/ad-rewarded

# === EXPORT ADS ===
^https?:\/\/api\.capcut\.com\/api\/v1\/export\/ad 302 https://api.capcut.com/api/v1/export/no-ad
^https?:\/\/api\.capcut\.com\/api\/v1\/export\/check 302 https://api.capcut.com/api/v1/export/ready
^https?:\/\/api\.capcut\.com\/api\/v1\/export\/require 302 https://api.capcut.com/api/v1/export/no-require
^https?:\/\/api\.capcut\.com\/api\/v1\/export\/status 302 https://api.capcut.com/api/v1/export/completed

# === WATERMARK ===
^https?:\/\/api\.capcut\.com\/api\/v1\/watermark 302 https://api.capcut.com/api/v1/watermark-removed
^https?:\/\/api\.capcut\.com\/api\/v1\/watermark\/check 302 https://api.capcut.com/api/v1/watermark-none

# === PREMIUM ===
^https?:\/\/api\.capcut\.com\/api\/v1\/premium 302 https://api.capcut.com/api/v1/premium-active
^https?:\/\/api\.capcut\.com\/api\/v1\/premium\/check 302 https://api.capcut.com/api/v1/premium/active
^https?:\/\/api\.capcut\.com\/api\/v1\/vip 302 https://api.capcut.com/api/v1/vip-active
^https?:\/\/api\.capcut\.com\/api\/v1\/subscription 302 https://api.capcut.com/api/v1/subscription/active

# === USER ===
^https?:\/\/api\.capcut\.com\/api\/v1\/user 302 https://api.capcut.com/api/v1/user-premium
^https?:\/\/api\.capcut\.com\/api\/v1\/user\/status 302 https://api.capcut.com/api/v1/user/vip-status

# === TRACKING ===
^https?:\/\/api\.capcut\.com\/api\/v1\/track 302 https://0.0.0.0/
^https?:\/\/api\.capcut\.com\/api\/v1\/event 302 https://0.0.0.0/
^https?:\/\/api\.capcut\.com\/api\/v1\/report 302 https://0.0.0.0/
^https?:\/\/api\.capcut\.com\/api\/v1\/log 302 https://0.0.0.0/
^https?:\/\/api\.capcut\.com\/api\/v1\/analytics 302 https://0.0.0.0/

# ===== LỚP 3: SCRIPT CAN THIỆP SÂU =====
[Script]
# Script giả lập đã xem quảng cáo
CapCut-Ads-Watcher = type=http-request, pattern=^https?:\/\/api\.capcut\.com\/api\/v1\/(ad|ads|export\/ad), script-path=ads-watcher.js

# Script giả lập Premium
CapCut-Premium-Faker = type=http-response, pattern=^https?:\/\/api\.capcut\.com\/api\/v1\/(user|vip|premium|subscription), script-path=premium-faker.js

# Script xử lý export
CapCut-Export-Handler = type=http-response, pattern=^https?:\/\/api\.capcut\.com\/api\/v1\/export, script-path=export-handler.js

# === NỘI DUNG SCRIPT ads-watcher.js ===
"""
// Giả lập đã xem quảng cáo thành công
$done({
    status: 200,
    headers: {
        "Content-Type": "application/json"
    },
    response: {
        code: 0,
        message: "success",
        data: {
            ad_viewed: true,
            ad_completed: true,
            ad_skipped: false,
            reward_claimed: true,
            view_time: 30000, // Đã xem 30 giây
            remaining_ads: 0,
            next_ad_time: 9999999999,
            can_export: true,
            export_without_ad: true,
            ad_free_trial: true,
            ad_free_until: "2099-12-31T23:59:59Z"
        }
    }
});
"""

# === NỘI DUNG SCRIPT premium-faker.js ===
"""
// Giả lập tài khoản Premium vĩnh viễn
const response = JSON.parse($response.body || '{}');
response.code = 0;
response.message = "success";
response.data = response.data || {};

// Thông tin user
response.data.user = response.data.user || {};
response.data.user.is_vip = true;
response.data.user.is_premium = true;
response.data.user.vip_type = "premium_yearly";
response.data.user.vip_expired = false;
response.data.user.vip_expire_time = "2099-12-31T23:59:59Z";
response.data.user.vip_level = 999;
response.data.user.vip_score = 999999;

// Quyền lợi Premium
response.data.user.can_export_4k = true;
response.data.user.can_export_60fps = true;
response.data.user.can_export_hdr = true;
response.data.user.no_watermark = true;
response.data.user.no_ad_export = true;
response.data.user.unlimited_export = true;
response.data.user.export_limit = 999999;
response.data.user.export_count = 0;
response.data.user.premium_features = [
    "no_watermark",
    "4k_export",
    "60fps_export",
    "hdr_export",
    "no_ads",
    "premium_effects",
    "premium_filters",
    "premium_stickers",
    "premium_texts",
    "premium_transitions",
    "cloud_storage_1tb"
];

// Subscription
response.data.subscription = {
    status: "active",
    type: "premium_yearly",
    platform: "apple",
    purchase_date: "2024-01-01T00:00:00Z",
    expiry_date: "2099-12-31T23:59:59Z",
    auto_renew: true,
    valid: true,
    grace_period: false,
    refunded: false
};

// Ads
response.data.ads = {
    show_ads: false,
    show_interstitial: false,
    show_banner: false,
    show_rewarded: false,
    ad_frequency: 0,
    last_ad_time: 0,
    next_ad_time: 9999999999,
    ads_watched_today: 0,
    max_ads_per_day: 999999
};

$done({body: JSON.stringify(response)});
"""

# === NỘI DUNG SCRIPT export-handler.js ===
"""
// Xử lý export không quảng cáo
const response = JSON.parse($response.body || '{}');
response.code = 0;
response.message = "success";
response.data = response.data || {};

// Thông tin export
response.data.export = response.data.export || {};
response.data.export.ready = true;
response.data.export.status = "processing";
response.data.export.progress = 100;
response.data.export.require_ad = false;
response.data.export.ad_viewed = true;
response.data.export.ad_skipped = false;
response.data.export.watermark = false;
response.data.export.quality = "4k";
response.data.export.fps = 60;
response.data.export.resolution = "3840x2160";
response.data.export.estimated_time = 0;
response.data.export.remaining_time = 0;
response.data.export.priority = "high";

// URL export (giả lập đã có sẵn)
response.data.export.url = "https://export.capcut.com/video/premium/export.mp4";
response.data.export.download_url = "https://download.capcut.com/video/premium/export.mp4";

// Không cần xem quảng cáo
response.data.ad_required = false;
response.data.ad_completed = true;
response.data.ad_skipped = true;
response.data.ad_viewed = true;

$done({body: JSON.stringify(response)});
"""

# ===== LỚP 4: MITM BẮT TOÀN BỘ =====
[MITM]
hostname = %APPEND% api.capcut.com, effect.capcut.com, *.bytedance.com, *.byteoversea.com
enable = true
skip-server-cert-verify = true

# ===== LỚP 5: MAP LOCAL - TRẢ VỀ RESPONSE GIẢ =====
[Map Local]
# User endpoints
^https?:\/\/api\.capcut\.com\/api\/v1\/user data-type=json data={"code":0,"message":"success","data":{"user":{"is_vip":true,"is_premium":true,"vip_type":"premium_yearly","vip_expired":false,"vip_expire_time":"2099-12-31T23:59:59Z","can_export_4k":true,"no_watermark":true,"no_ad_export":true}}} status-code=200

# Premium check
^https?:\/\/api\.capcut\.com\/api\/v1\/premium\/check data-type=json data={"code":0,"message":"success","data":{"is_premium":true,"premium_until":"2099-12-31T23:59:59Z","features":["no_ads","4k_export","no_watermark"]}} status-code=200

# Export check
^https?:\/\/api\.capcut\.com\/api\/v1\/export\/check data-type=json data={"code":0,"message":"success","data":{"can_export":true,"require_ad":false,"ad_completed":true,"watermark_removed":true,"quality_available":["480p","720p","1080p","4k"]}} status-code=200

# Ad check
^https?:\/\/api\.capcut\.com\/api\/v1\/ad\/check data-type=json data={"code":0,"message":"success","data":{"show_ad":false,"ad_viewed":true,"ad_completed":true,"next_ad_time":9999999999,"remaining_ads":0}} status-code=200

# Subscription
^https?:\/\/api\.capcut\.com\/api\/v1\/subscription data-type=json data={"code":0,"message":"success","data":{"status":"active","type":"premium_yearly","expiry":"2099-12-31T23:59:59Z","auto_renew":true}} status-code=200

# ===== LỚP 6: HEADER REWRITE - XÓA DẤU VẾT =====
[Header Rewrite]
^https?:\/\/api\.capcut\.com\/.* header-replace X-Device-ID "PREMIUM-DEVICE-999999"
^https?:\/\/api\.capcut\.com\/.* header-replace X-User-ID "PREMIUM-USER-999999"
^https?:\/\/api\.capcut\.com\/.* header-replace X-Tracking-ID "DISABLED"
^https?:\/\/api\.capcut\.com\/.* header-replace X-Ad-ID "COMPLETED"
^https?:\/\/api\.capcut\.com\/.* header-replace X-Ad-View-Time "30000"

# ===== LỚP 7: HOST FILE CHẶN =====
[Host]
127.0.0.1 ads.capcut.com
127.0.0.1 tracking.capcut.com
127.0.0.1 analytics.capcut.com
127.0.0.1 monitor.capcut.com
127.0.0.1 log.capcut.com
127.0.0.1 event.capcut.com
127.0.0.1 report.capcut.com
127.0.0.1 statistic.capcut.com
