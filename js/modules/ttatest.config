^https?:\/\/.*\.unityads\.unity3d\.com\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.applovin\.com\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.vungle\.com\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.ironsrc\.com\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.ironsrc\.net\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.supersonicads\.com\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.chartboost\.com\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.adcolony\.com\/.* 302 https://127.0.0.1/
^https?:\/\/.*\.tapjoy\.com\/.* 302 https://127.0.0.1/

[Header Rewrite]
http-request ^https?://api.revenuecat.com/.+/(receipts$|subscribers/?(.*?)*$) header-del x-revenuecat-etag
http-request ^https?://api.revenuecat.com/.+/(receipts$|subscribers/?(.*?)*$) header-del X-RevenueCat-ETag

# ===== Spotify iOS15 Header Rewrite =====
http-request ^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/user-customization-service\/v1\/customize$ header-del if-none-match
http-request ^https?://api.revenuecat.com/.+/(receipts$|subscribers/?(.*?)*$) header-del x-revenuecat-etag
http-request ^https?://api.revenuecat.com/.+/(receipts$|subscribers/?(.*?)*$) header-del X-RevenueCat-ETag
http-request ^https?://api\.revenuecat\.com/.+/(receipts$|subscribers/?(.*?)*$) header-del x-revenuecat-etag
http-request ^https?://api\.revenuecat\.com/.+/(receipts$|subscribers/?(.*?)*$) header-del X-RevenueCat-ETag
http-request ^https?://(www|s)\.youtube\.com/pagead/ header-del Referer
http-request ^https?://(www|s)\.youtube\.com/ptracking header-del Referer
http-request ^https?://api.revenuecat.com/.+/(receipts$|subscribers/?(.*?)*$) header-del x-revenuecat-etag
http-request ^https?://api.revenuecat.com/.+/(receipts$|subscribers/?(.*?)*$) header-del X-RevenueCat-ETag

# ===== Castle Clashers Header Rewrite =====
http-request ^https?:\/\/.*\.(unity3d|applovin|vungle|ironsrc|supersonicads)\.com\/.* header-del User-Agent
http-request ^https?:\/\/.*\.(unity3d|applovin|vungle|ironsrc|supersonicads)\.com\/.* header-del Cookie

# CapCut Premium
http-request CapCut-Premium = type=http-response,pattern=^https?:\/\/api(.*)\.capcut\.com\/v1\/(user|vip|premium),script-path=https://raw.githubusercontent.com/Semporia/Quantumult-X/master/Scripts/CapCut.js,requires-body=true,max-size=0
http-request CapCut-Unlock = type=http-response,pattern=^https?:\/\/(api|effect)\.(capcut|bytedance)\.com\/(api\/v1\/vip_info|effect\/api\/v1\/premium\/user_status)/,script-path=https://raw.githubusercontent.com/nameking77/Qx/main/script/capcut.js,requires-body=true

# Netflix
http-request Netflix-AdSkip = type=http-response,pattern=^https?:\/\/(ios\.prod\.ftl|www)\.netflix\.com\/,script-path=https://raw.githubusercontent.com/deezertidal/QuantumultX-Rewrite/master/rewrite/netflix.conf,requires-body=true
http-request Netflix-4K = type=http-request,pattern=^https?:\/\/www\.netflix\.com\/nq\/mvilayer,script-path=https://raw.githubusercontent.com/deezertidal/QuantumultX-Rewrite/master/js/netflix_4k.js

# Ad Skip Universal
http-request AdSkip-Universal = type=http-response,pattern=^https?:\/\/(.*)(ad|ads|adx|adv|doubleclick)\.(.*),script-path=https://raw.githubusercontent.com/deezertidal/QuantumultX-Rewrite/master/js/0s-ads.js,requires-body=true
